# PostgreSQL Database Configuration
# Preferred for hosted environments:
# DATABASE_URL=postgres://user:password@host:5432/database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zetechverse
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_KEEP_ALIVE=true
DB_KEEP_ALIVE_INITIAL_DELAY_MS=10000
DB_CONNECT_RETRY_ATTEMPTS=5
DB_CONNECT_RETRY_DELAY_MS=2000

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:8081,https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173
APP_NAME=ZetechVerse

# Password reset email (SMTP)
PASSWORD_RESET_SECRET=your_password_reset_secret_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=ZetechVerse <no-reply@your-domain.com>
SMTP_REPLY_TO=support@your-domain.com

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Uploads and request body limits
# Raw upload max size in MB (applies to /api/uploads/media)
UPLOAD_MAX_FILE_SIZE_MB=100
# Optional persistent uploads directory path.
# Relative paths resolve from the backend process working directory.
# UPLOADS_DIR=uploads
# Optional public base URL used when constructing media links (useful behind proxies/CDN).
# Example: https://api.your-domain.com
# UPLOAD_PUBLIC_BASE_URL=
# Optional overall request body parser limit in MB.
# If omitted, it is auto-derived from UPLOAD_MAX_FILE_SIZE_MB for base64 payload overhead.
# REQUEST_BODY_LIMIT_MB=150

# M-Pesa (Safaricom Daraja) Configuration
# Use sandbox values for development and switch MPESA_ENV=production for live traffic.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
# Public HTTPS URL that Daraja can reach (ngrok/domain). If only base URL is provided,
# /api/payments/mpesa/callback will be appended automatically.
MPESA_CALLBACK_URL=https://your-public-domain-or-ngrok-url
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# Other Configuration (if needed)
# DATABASE_PATH=../database/zetechverse.db  # Legacy SQLite path (no longer needed)
